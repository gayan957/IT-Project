# PayHere Configuration (Add these to your .env file)

# PayHere Sandbox Configuration
PAYHERE_MERCHANT_ID=your_merchant_id_here
PAYHERE_MERCHANT_SECRET=your_merchant_secret_here
PAYHERE_SANDBOX_URL=https://sandbox.payhere.lk/pay/checkout
PAYHERE_LIVE_URL=https://www.payhere.lk/pay/checkout

# PayHere API Configuration
PAYHERE_API_URL=https://sandbox.payhere.lk/merchant/v1
PAYHERE_API_USERNAME=your_api_username
PAYHERE_API_PASSWORD=your_api_password

# Webhook Configuration
PAYHERE_WEBHOOK_SECRET=your_webhook_secret_key

# Frontend URLs for PayHere redirects
FRONTEND_SUCCESS_URL=http://localhost:5173/payment-success
FRONTEND_CANCEL_URL=http://localhost:5173/collect-schedule-waste
FRONTEND_ERROR_URL=http://localhost:5173/payment-error

# Application Settings
NODE_ENV=development
JWT_SECRET=your_jwt_secret_key
MONGODB_URI=mongodb://localhost:27017/trash2cash

# CORS Settings
CORS_ORIGIN=http://localhost:5173